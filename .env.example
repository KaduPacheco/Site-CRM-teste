# Ambiente de testes somente. Nunca reutilize valores do ambiente principal.
# Obrigatorias para a landing publica e para o CRM autenticado.
VITE_SUPABASE_URL=https://YOUR-TEST-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_TEST_SUPABASE_ANON_KEY

# Opcional: defina apenas se a ingestao da landing usar um endpoint diferente de /rest/v1/leads.
# Quando vazio, o frontend usa ${VITE_SUPABASE_URL}/rest/v1/leads.
VITE_SUPABASE_INTAKE_URL=

# Opcional: mantenha vazio se nao houver webhook isolado para o ambiente de testes.
# O webhook nao substitui a gravacao principal no Supabase.
VITE_N8N_WEBHOOK_URL=
